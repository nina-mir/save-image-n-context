{
  "manifest_version": 3,
  "name": "Save Image 'n Context",
  "version": "0.5",
  "description": "Right-click any web image to save it and keep a local citation log: source page, caption, nearby text, and metadata.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Save Image 'n Context"
  },
  "permissions": ["contextMenus", "storage", "downloads", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options/options.html"
}
